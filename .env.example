# Copy to .env for local dev:  cp .env.example .env
# For GitHub Pages (Actions deploy), add the same keys under:
#   Repo → Settings → Secrets and variables → Actions → New repository secret

# Web3Forms access key — https://web3forms.com (sign up with rulete.jeric@gmail.com)
VITE_WEB3FORMS_ACCESS_KEY=your_web3forms_access_key

# hCaptcha site key — https://www.hcaptcha.com/
VITE_HCAPTCHA_SITE_KEY=your_hcaptcha_site_key